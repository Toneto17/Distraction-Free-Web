{
  "manifest_version": 3,
  "name": "Distraction Free Web",
  "version": "2.2.8",
  "description": "Block doomscrolling, set local daily time limits, and reclaim your focus.",
  "minimum_chrome_version": "121",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://youtube.com/*",
    "*://*.youtube.com/*",
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "*://twitch.tv/*",
    "*://*.twitch.tv/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://facebook.com/*",
    "*://*.facebook.com/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://reddit.com/*",
    "*://*.reddit.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Distraction Free Web",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*",
        "*://twitch.tv/*",
        "*://*.twitch.tv/*",
        "*://linkedin.com/*",
        "*://*.linkedin.com/*",
        "*://instagram.com/*",
        "*://*.instagram.com/*",
        "*://facebook.com/*",
        "*://*.facebook.com/*",
        "*://tiktok.com/*",
        "*://*.tiktok.com/*",
        "*://reddit.com/*",
        "*://*.reddit.com/*"
      ],
      "css": [
        "styles/overlays.css"
      ],
      "js": [
        "config/rules.js",
        "scripts/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
