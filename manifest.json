{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "2.1.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "distraction-free-web@toneto17",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": ["scripts/background.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Distraction Free Web",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": [
        "styles/overlays.css"
      ],
      "js": [
        "config/rules.js",
        "scripts/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
